{
  "version": 2,
  "env": {
    "APP_KEY": "base64:fHKF0x55LT2sEnin5nM5WI9DztXu36lySsCYpKa8mvs=",
    "APP_ENV": "production",
    "APP_DEBUG": "true"
  },
  "builds": [
    {
      "src": "api/*.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    {
      "src": "/(images|css|js|favicon.ico)(.*)",
      "dest": "/public/$1$2"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/backend.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}