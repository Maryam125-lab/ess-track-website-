{
  "version": 2,
  "env": {
    "APP_KEY": "base64:fHKF0x55LT2sEnin5nM5WI9DztXu36lySsCYpKa8mvs=",
    "APP_ENV": "production",
    "APP_DEBUG": "false"
  },
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/backend.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}